@page "/products"
@inject ApiService Api

<PageTitle>Products</PageTitle>

<div class="container py-3">
    <h3 class="mb-3">Products</h3>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @messageClass" role="alert">@message</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Add Product</h5>
            <form @onsubmit="CreateProductAsync">
                <div class="row g-2">
                    <div class="col-md-4">
                        <input class="form-control" placeholder="Name" @bind="newProduct.Name" required />
                    </div>
                    <div class="col-md-3">
                        <input class="form-control" type="number" step="0.01" min="0" placeholder="Price"
                               @bind="newProduct.Price" required />
                    </div>
                    <div class="col-md-3">
                        <input class="form-control" type="number" min="0" placeholder="Stock" @bind="newProduct.Stock"
                               required />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button class="btn btn-primary" type="submit">Add</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (products is null)
    {
        <p>Loading products...</p>
    }
    else if (products.Count == 0)
    {
        <p>No products found.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var product in products)
            {
                <div class="col-md-4">
                    <ProductCard Product="product" />
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductDto>? products;
    private CreateProductDto newProduct = new();
    private string? message;
    private string messageClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        products = await Api.GetProductsAsync();
    }

    private async Task CreateProductAsync()
    {
        message = null;

        var created = await Api.CreateProductAsync(newProduct);
        if (created is null)
        {
            message = "Failed to create product. Check gateway and service availability.";
            messageClass = "alert-danger";
            return;
        }

        newProduct = new CreateProductDto();
        products = await Api.GetProductsAsync();
        message = "Product created.";
        messageClass = "alert-success";
    }
}
