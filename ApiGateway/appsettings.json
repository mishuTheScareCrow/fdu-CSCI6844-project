{
  "ServiceUrls": {
    "CustomerService": "http://customerservice:8080/",
    "ProductService": "http://productservice:8080/",
    "OrderService": "http://orderservice:8080/"
  },
  "ReverseProxy": {
    "Routes": {
      "customers-public-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Methods": [ "GET", "POST" ],
          "Path": "/customers"
        },
        "Transforms": [
          {
            "PathSet": "/api/customers"
          }
        ]
      },
      "products-public-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Methods": [ "GET", "POST" ],
          "Path": "/products"
        },
        "Transforms": [
          {
            "PathSet": "/api/products"
          }
        ]
      },
      "orders-public-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Methods": [ "GET", "POST" ],
          "Path": "/orders"
        },
        "Transforms": [
          {
            "PathSet": "/api/orders"
          }
        ],
        "Order": 50
      },
      "customers-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Order": 100
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "customers-swagger-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/docs/customers/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/customers"
          }
        ]
      },
      "products-swagger-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/docs/products/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/products"
          }
        ]
      },
      "orders-swagger-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/docs/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/orders"
          }
        ]
      },
      "payments-swagger-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/docs/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/docs/payments"
          }
        ]
      }
    },
    "Clusters": {
      "customers-cluster": {
        "Destinations": {
          "customers-destination": {
            "Address": "http://customerservice:8080/"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "products-destination": {
            "Address": "http://productservice:8080/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-destination": {
            "Address": "http://orderservice:8080/"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-destination": {
            "Address": "http://paymentservice:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
