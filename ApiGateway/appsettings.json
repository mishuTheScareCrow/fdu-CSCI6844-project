{
  "ServiceUrls": {
    "CustomerService": "http://customerservice:8080/",
    "ProductService": "http://productservice:8080/",
    "OrderService": "http://orderservice:8080/"
  },
  "ReverseProxy": {
    "Routes": {
      "customers-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Order": 100
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "customers-cluster": {
        "Destinations": {
          "customers-destination": {
            "Address": "http://customerservice:8080/"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "products-destination": {
            "Address": "http://productservice:8080/"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-destination": {
            "Address": "http://orderservice:8080/"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-destination": {
            "Address": "http://paymentservice:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
